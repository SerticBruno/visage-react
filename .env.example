# Kopiraj u .env.local za lokalni razvoj (nikad ne commitaj prave ključeve).

# --- Lokalno: Stripe TEST (https://dashboard.stripe.com/test/apikeys) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Nakon `npm run stripe:listen` - signing secret iz terminala:
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Produkcija (Vercel → Settings → Environment Variables → Production) ---
# NEXT_PUBLIC_SITE_URL=https://visagestudio.hr
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # Live webhook na /api/webhooks/stripe

# Supabase (Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
# ili legacy: SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Besplatna dostava (BoxNow/GLS) iznad ovog iznosa proizvoda u EUR
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD_EUR=30

# Podaci o prodavatelju (zakonske stranice — obavezno u produkciji)
# NEXT_PUBLIC_SELLER_LEGAL_NAME=VISAGE Studio, obrt za ...
# NEXT_PUBLIC_SELLER_OIB=12345678901
# NEXT_PUBLIC_SELLER_MBS=
# NEXT_PUBLIC_SELLER_COURT=Trgovački sud u Zagrebu
# NEXT_PUBLIC_SELLER_SHARE_CAPITAL=
# NEXT_PUBLIC_SELLER_RESPONSIBLE_PERSON=

# Google Tag Manager (analitika — uz cookie privolu)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Gmail (kontakt forma, potvrde narudžbi, narudžbe dobavljačima)
# Kreiraj App Password: Google račun → Sigurnost → 2FA → Lozinke za aplikacije
GMAIL_USER=info@visagestudio.hr
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Opcionalno — kopija internih obavijesti
# GMAIL_USER_2=
# GMAIL_USER_3=

# Dobavljači po marki (JSON niz u jednom retku)
# Svaka marka iz kataloga (polje marka) mapira se na email dobavljača.
# Primjer za TOSKANI, Circadia i Profhilo:
SUPPLIERS_JSON=[{"marka":"TOSKANI","name":"Toskani","email":"narudzbe@toskani.com","contactName":"Ana"},{"marka":"Circadia","name":"Circadia Professional","email":"orders@circadia.com","contactName":"Tim"},{"marka":"Profhilo","name":"Profhilo distributer","email":"narudzbe@profhilo.hr"}]

# Resend (back-in-stock i abandoned cart emailovi)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=info@visagestudio.hr

# Brevo / Sendinblue (newsletter)
# BREVO_API_KEY=
# BREVO_LIST_ID=

# Abandoned cart recovery — mailovi se šalju ručno iz admin panela (/admin/abandoned-carts)

# ─── Google Calendar (termini) ─────────────────────────────────────────────────
# 1. Idi na https://console.cloud.google.com/ → New Project
# 2. APIs & Services → Enable "Google Calendar API"
# 3. Credentials → OAuth 2.0 Client ID (Web application)
# 4. Authorized redirect URI: https://visagestudio.hr/api/admin/google-calendar/callback
#    (lokalno: http://localhost:3000/api/admin/google-calendar/callback)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# GOOGLE_CALENDAR_REDIRECT_URI=https://visagestudio.hr/api/admin/google-calendar/callback

# Vercel Cron zaštita (opcija — postavi isti secret u Vercel Environment Variables)
# CRON_SECRET=neki-tajni-string
